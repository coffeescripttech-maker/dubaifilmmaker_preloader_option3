{
  "activePreset": "",
  "description": "Header configuration - switch between different header layouts and logo styles",
  "presets": {
    "reversed": {
      "name": "Reversed Layout",
      "description": "Logo right, menu left - comprehensive layout with navigation positioning",
      "logo": {
        "src": "assets/img/final_logo.svg",
        "srcDark": "assets/img/final_logo.svg",
        "alt": "DubaiFilmMaker"
      },
      "introAnimation": {
        "type": "text",
        "text": "DUBAIFILMMAKER",
        "initialPattern": "DMAKER",
        "holdDuration": 3000,
        "revealStartTime": 3480
      },
      "mobile": {
        "headerNav": {
          "alignItems": "center",
          "padding": "0px",
          "minHeight": "50px",
          "flexDirection": "row-reverse",
          "justifyContent": "space-between",
          "gap": "24px",
          "width": "100%"
        },
        "logoLink": {
          "maxWidth": "180px",
          "flexShrink": "0",
          "paddingRight": "0px",
          "width": "auto",
          "margin": "0"
        },
        "logo": {
          "maxHeight": "70px",
          "maxWidth": "100%",
          "width": "auto",
          "margin": "0"
        },
        "menuButton": {
          "width": "auto",
          "flexShrink": "0",
          "margin": "0",
          "position": "relative"
        },
        "navigationWrapper": {
          "left": "0",
          "right": "auto"
        },
        "subNav": {
          "left": "0",
          "right": "auto",
          "textAlign": "left"
        },
        "subNavUl": {
          "alignItems": "flex-start",
          "paddingLeft": "20px",
          "paddingRight": "20px"
        },
        "subNavLi": {
          "textAlign": "left"
        },
        "subNavLink": {
          "justifyContent": "flex-start",
          "textAlign": "left"
        },
        "menuButtonOpen": {
          "clipPath": "inset(0 calc(100% - 34px) 0 0 round 20px)"
        },
        "menuButtonOpenBefore": {
          "left": "0",
          "right": "auto"
        }
      },
      "desktop": {
        "headerNav": {
          "flexDirection": "row-reverse",
          "justifyContent": "space-between",
          "gap": "24px",
          "alignItems": "center",
          "width": "100%",
          "minHeight": "50px"
        },
        "logoLink": {
          "width": "auto",
          "flexShrink": "0",
          "margin": "0"
        },
        "logo": {
          "maxHeight": "80px",
          "width": "auto",
          "margin": "0"
        },
        "navigationWrapper": {
          "left": "0",
          "right": "auto"
        },
        "subNav": {
          "left": "0",
          "right": "auto"
        },
        "subNavUl": {
          "alignItems": "flex-start",
          "paddingLeft": "30px"
        },
        "subNavLink": {
          "justifyContent": "flex-start",
          "textAlign": "left"
        }
      },
      "extraLarge": {
        "logo": {
          "maxHeight": "100px"
        }
      }
    }
  }
}
